{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommits',
  ],
  separateMajorMinor: false,
  separateMinorPatch: false,

  customManagers: [
    {
      customType: 'regex',
      description: 'Container image references in Helm values (imageName field)',
      managerFilePatterns: [
        '/helm/.+/values\\.yaml$/',
      ],
      matchStrings: [
        'imageName:\\s*(?<depName>[^:]+):(?<currentValue>[^\\s]+)',
      ],
      datasourceTemplate: 'docker',
    },
    {
      customType: 'regex',
      description: 'Track Hiroba template version in catalog-info.yaml',
      managerFilePatterns: ['/catalog-info\\.yaml$/'],
      matchStrings: [
        'hiroba\\.7kgroup\\.org/template-version:\\s*(?<currentValue>[^\\s]+)',
      ],
      depNameTemplate: '7K-Hiroba/Hiroba',
      datasourceTemplate: 'github-tags',
      extractVersionTemplate: '^app-template-v(?<version>.+)$',
    },
    {
      customType: 'regex',
      description: 'Track upstream Vikunja image via Chart.yaml appVersion',
      managerFilePatterns: [
        '/helm/(base|platform)/Chart\\.yaml$/',
      ],
      matchStrings: [
        'appVersion:\\s*"?(?<currentValue>[^"\\s]+)"?',
      ],
      depNameTemplate: 'vikunja/vikunja',
      datasourceTemplate: 'docker',
      versioningTemplate: 'docker',
    },
  ],
  packageRules: [
    {
      description: 'Group Dockerfile base image updates',
      matchManagers: ['dockerfile'],
      groupName: 'docker-base-images',
      semanticCommitType: 'fix',
      semanticCommitScope: 'docker',
    },
    {
      description: 'Group GitHub Actions updates',
      matchManagers: [
        'github-actions',
      ],
      groupName: 'github-actions',
      semanticCommitType: 'ci',
    },
    {
      description: 'Hiroba template version updates',
      matchPackageNames: ['7K-Hiroba/Hiroba'],
      groupName: 'hiroba-template',
      semanticCommitType: 'fix',
      semanticCommitScope: 'hiroba',
    },
    {
      description: 'Bump both charts together when upstream Vikunja image moves',
      matchPackageNames: [
        'vikunja/vikunja',
      ],
      groupName: 'vikunja-app',
      semanticCommitType: 'fix',
      semanticCommitScope: 'helm',
    },
    {
      description: 'Platform chart dependency updates',
      matchFileNames: [
        'helm/platform/**',
      ],
      semanticCommitType: 'fix',
      semanticCommitScope: 'helm-platform',
    },
  ],
}
